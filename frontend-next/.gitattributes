# Normalize all text files to LF in the repo and working tree.
# Prevents the CRLF/prettier flood on Windows checkouts.
* text=auto eol=lf

# Binary assets — never normalize or diff as text.
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.webp binary
*.avif binary
*.woff binary
*.woff2 binary
*.ttf binary
*.eot binary
*.pdf binary
