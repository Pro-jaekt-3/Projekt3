# frontend-next environment — copy to frontend-next/.env and fill real values.
# Do NOT commit .env (it holds secrets). This .example file is the reference.

# Backend REST API base URL (Express server).
VITE_API_URL=http://localhost:3000

# Firebase Web SDK config (same project as the existing frontend/).
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_MEASUREMENT_ID=

# DEV-ONLY role override for previewing all roles without multiple Firebase accounts.
# Set to one of: admin | instructor | participant  (any non-empty value enables it).
# Has effect ONLY in `vite dev` (import.meta.env.DEV); a production build ignores it.
VITE_DEV_ROLE_OVERRIDE=
