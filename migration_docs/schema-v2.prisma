// =============================================================================
// PROJEKT3 — schema-v2.prisma  (PREDLOG, NEAKTIVEN)
// -----------------------------------------------------------------------------
// To NI aktivna shema. Odloži jo v repo kot referenco (npr. prisma/schema-v2.prisma)
// in NE poganjaj migracij, dokler ne pregledata menjave v ločenem chatu (Korak 3).
//
// Legenda oznak v komentarjih:
//   [NEW]      = nova tabela / stolpec / relacija
//   [CHANGED]  = spremenjeno glede na staro shemo
//   [REMOVED]  = odstranjeno glede na staro shemo (navedeno, kje je bilo)
//   [ADD]      = additivno (ne podre obstoječega API/frontend kontrakta)
//   [BREAK]    = rušilno (zahteva frontend follow-up — glej NOTES §Rušilno)
//   [BACKFILL] = potrebuje migracijo podatkov pred uveljavitvijo (glej NOTES)
//   [APP]      = pravilo, ki ga FK ne izrazi; uveljavi ga koda
// =============================================================================

generator client {
  provider = "prisma-client-js"
}

generator erd {
  provider = "prisma-erd-generator"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// =============================================================================
// USER
// =============================================================================
model User {
  id             Int      @id @default(autoincrement())
  firebaseUid    String?  @unique
  email          String   @unique
  name           String?
  externalAuthId String?  @unique // legacy/seed auth pot; Firebase middleware fallback. OHRANJENO.
  role           UserRole @default(PARTICIPANT) // globalni tier; per-training vloga je v UserTraining.

  createdAt DateTime @default(now()) // [NEW][ADD] audit; obstoječe vrstice dobijo now() ob migraciji
  updatedAt DateTime @updatedAt      // [NEW][ADD]

  createdQuestions        Question[]          @relation("QuestionCreatedBy")
  assessmentAttempts      AssessmentAttempt[]
  requestedAiInteractions AiInteraction[]     @relation("AiInteractionRequestedBy")
  gradedAnswers           ParticipantAnswer[] @relation("AnswerGradedBy") // [NEW] ročno ocenjevanje
  trainingMemberships     UserTraining[] // [NEW] lastništvo + enrollment

  // [REMOVED] reviewedQuestions        (Question.reviewedById odpade)
  // [REMOVED] reviewedAiInteractions   (AiInteraction.reviewedById odpade)
}

// =============================================================================
// TRAINING  (koren; lastništvo izhaja iz UserTraining, ne iz FK navzgor)
// =============================================================================
model Training {
  id          Int     @id @default(autoincrement())
  title       String
  description String?

  enrollmentToken String? @unique // [NEW][ADD] za QR self-enrollment; koda ga generira/regenerira

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  topics            Topic[]
  assessments       Assessment[]
  members           UserTraining[]     // [NEW]
  equivalenceGroups EquivalenceGroup[] // [NEW] ekvivalenca je scope-ana na training

  // [REMOVED] assessmentBlueprints  (AssessmentBlueprint tabela odpade — mrtva shema)
}

// =============================================================================
// UserTraining  [NEW]  — vezna tabela User <-> Training (M:N)
//   role=INSTRUCTOR  -> lastništvo (co-teaching mogoč: več instructorjev na training)
//   role=PARTICIPANT -> enrollment (dostop do PUBLISHED assessmentov tega treninga)
// =============================================================================
model UserTraining {
  id         Int          @id @default(autoincrement())
  userId     Int
  user       User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  trainingId Int
  training   Training     @relation(fields: [trainingId], references: [id], onDelete: Cascade)
  role       TrainingRole
  enrolledAt DateTime     @default(now())

  @@unique([userId, trainingId]) // en member = ena vloga na training
  @@index([trainingId, role]) // "instruktorji/udeleženci tega treninga"
}

// =============================================================================
// TOPIC
// =============================================================================
model Topic {
  id         Int      @id @default(autoincrement())
  name       String
  trainingId Int
  training   Training @relation(fields: [trainingId], references: [id])

  createdAt DateTime @default(now()) // [NEW][ADD]
  updatedAt DateTime @updatedAt      // [NEW][ADD]

  questions Question[]

  // [REMOVED] learningObjectives  (LearningObjective tabela odpade)
}

// =============================================================================
// QUESTION
// =============================================================================
model Question {
  id          Int    @id @default(autoincrement())
  title       String
  description String @db.Text // [CHANGED][ADD] bilo VARCHAR(191) -> TEXT (CODE/OPEN vsebina)
  difficulty  Int

  type   QuestionType   @default(OPEN)
  status QuestionStatus @default(DRAFT)

  topicId Int
  topic   Topic @relation(fields: [topicId], references: [id])

  createdById Int
  createdBy   User @relation("QuestionCreatedBy", fields: [createdById], references: [id])

  reviewedAt DateTime? // OHRANJENO (kdaj potrjeno); reviewedById odpade

  equivalenceGroupId Int? // [CHANGED] preimenovano iz equivalentGroupId; kaže na novo EquivalenceGroup
  equivalenceGroup   EquivalenceGroup? @relation(fields: [equivalenceGroupId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now()) // [NEW][ADD] question bank ni imel timestampov
  updatedAt DateTime @updatedAt      // [NEW][ADD]

  answerOptions           AnswerOption[]
  assessmentQuestions     AssessmentQuestion[]
  participantAnswers      ParticipantAnswer[]
  sourceAiInteractions    AiInteraction[]      @relation("AiInteractionSourceQuestion")
  generatedAiInteractions AiInteraction[]      @relation("AiInteractionGeneratedQuestion")

  @@index([equivalenceGroupId])
  @@index([status, topicId]) // [NEW][ADD] filter banke: "APPROVED vprašanja te teme"

  // [REMOVED] learningObjectiveId / learningObjective
  // [REMOVED] reviewedById / reviewedBy
  // [APP] question.topic.trainingId mora biti enak equivalenceGroup.trainingId (če je v skupini)
}

// =============================================================================
// EquivalenceGroup  [NEW]  — čista različica stare EquivalentQuestionGroup
//   Popravki: (1) scope na training, (2) app pravilo >=2 člana za "uporabno",
//   (3) dedup — največ en član skupine na assessment (uveljavi generacija testa).
// =============================================================================
model EquivalenceGroup {
  id          Int      @id @default(autoincrement())
  trainingId  Int
  training    Training @relation(fields: [trainingId], references: [id]) // RESTRICT (kot ostali otroci treninga)
  title       String?
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  questions Question[]

  @@index([trainingId])
  // [APP] vsa vprašanja skupine morajo deliti isti trainingId
  // [APP] prazne/singleton skupine se počistijo (stara shema jih je puščala: 5/17)
}

// =============================================================================
// ANSWER OPTION
// =============================================================================
model AnswerOption {
  id         Int      @id @default(autoincrement())
  questionId Int
  question   Question @relation(fields: [questionId], references: [id], onDelete: Cascade)
  text       String
  isCorrect  Boolean  @default(false)
  orderIndex Int

  participantAnswers ParticipantAnswer[]

  @@unique([questionId, orderIndex])
  @@index([questionId])
}

// =============================================================================
// ASSESSMENT  (+ pre/post pairing kot samopovezava)
// =============================================================================
model Assessment {
  id               Int              @id @default(autoincrement())
  title            String
  description      String?
  trainingId       Int
  training         Training         @relation(fields: [trainingId], references: [id])
  type             AssessmentType
  status           AssessmentStatus @default(DRAFT)
  timeLimitMinutes Int?

  // [NEW] Pre/Post pairing — konvencija: POST_TEST.pairedAssessmentId = pripadajoči PRE_TEST.id
  pairedAssessmentId Int?        @unique // @unique => 1:1 (en pre ima največ en post)
  pairedAssessment   Assessment? @relation("AssessmentPairing", fields: [pairedAssessmentId], references: [id], onDelete: SetNull)
  pairedBy           Assessment? @relation("AssessmentPairing") // obratna stran (pre <- post)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  questions AssessmentQuestion[]
  attempts  AssessmentAttempt[]

  @@index([status, trainingId]) // [NEW][ADD] "PUBLISHED assessmenti tega treninga"
  // [APP] paired par: isti trainingId + komplementaren type (post <-> pre)
}

// =============================================================================
// ASSESSMENT QUESTION  (M:N vez Assessment <-> Question)
// =============================================================================
model AssessmentQuestion {
  id           Int        @id @default(autoincrement())
  assessmentId Int
  assessment   Assessment @relation(fields: [assessmentId], references: [id], onDelete: Cascade)
  questionId   Int
  question     Question   @relation(fields: [questionId], references: [id])
  orderIndex   Int
  points       Float      @default(1)

  @@unique([assessmentId, orderIndex])
  @@unique([assessmentId, questionId])
  @@index([questionId])
  // [APP] question.topic.trainingId == assessment.trainingId (prepreči cross-training uhajanje)
  // [APP] samo Question.status=APPROVED sme v assessment
}

// =============================================================================
// ASSESSMENT ATTEMPT
// =============================================================================
model AssessmentAttempt {
  id           Int           @id @default(autoincrement())
  assessmentId Int
  assessment   Assessment    @relation(fields: [assessmentId], references: [id])
  userId       Int // [CHANGED][BACKFILL] bilo Int? / SetNull -> zdaj NOT NULL / Restrict
  user         User          @relation(fields: [userId], references: [id])
  startedAt    DateTime      @default(now())
  submittedAt  DateTime?
  score        Float?
  maxScore     Float?
  status       AttemptStatus @default(IN_PROGRESS)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  answers ParticipantAnswer[]

  @@unique([assessmentId, userId]) // [NEW][BACKFILL] en poskus na test na uporabnika (D)
  @@index([userId])
  @@index([status])
  // [APP] /start dovoljen samo če: assessment.status=PUBLISHED IN user ima
  //       UserTraining(role=PARTICIPANT) za assessment.trainingId
}

// =============================================================================
// PARTICIPANT ANSWER
// =============================================================================
model ParticipantAnswer {
  id                Int               @id @default(autoincrement())
  attemptId         Int
  attempt           AssessmentAttempt @relation(fields: [attemptId], references: [id], onDelete: Cascade)
  questionId        Int
  question          Question          @relation(fields: [questionId], references: [id])
  selectedOptionId  Int?
  selectedOption    AnswerOption?     @relation(fields: [selectedOptionId], references: [id], onDelete: SetNull)
  answerText        String?           @db.Text // [CHANGED][ADD] bilo VARCHAR(191) -> TEXT (OPEN/CODE)
  isCorrect         Boolean?
  pointsAwarded     Float?
  needsManualReview Boolean           @default(false)

  gradedById Int? // [NEW][ADD] kdo je ročno ocenil (OPEN/CODE); NULL za MC/še neocenjeno
  gradedBy   User?     @relation("AnswerGradedBy", fields: [gradedById], references: [id], onDelete: SetNull)
  gradedAt   DateTime? // [NEW][ADD]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([attemptId, questionId])
  @@index([questionId])
  @@index([selectedOptionId])
  @@index([gradedById]) // [NEW]
}

// =============================================================================
// AI MODEL
// =============================================================================
model AiModel {
  id           Int             @id @default(autoincrement())
  provider     AiProvider
  modelName    String
  displayName  String?
  baseUrl      String?
  isLocal      Boolean         @default(false)
  isActive     Boolean         @default(true)
  interactions AiInteraction[]
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt

  @@unique([provider, modelName])
}

// =============================================================================
// AI INTERACTION  (advisory; reviewedById odpade, reviewStatus+reviewedAt ostaneta)
// =============================================================================
model AiInteraction {
  id                  Int            @id @default(autoincrement())
  aiModelId           Int
  aiModel             AiModel        @relation(fields: [aiModelId], references: [id])
  requestedById       Int
  requestedBy         User           @relation("AiInteractionRequestedBy", fields: [requestedById], references: [id])
  action              AiAction
  prompt              String         @db.LongText
  resultText          String?        @db.LongText
  resultJson          Json?
  sourceQuestionId    Int?
  sourceQuestion      Question?      @relation("AiInteractionSourceQuestion", fields: [sourceQuestionId], references: [id], onDelete: SetNull)
  generatedQuestionId Int?
  generatedQuestion   Question?      @relation("AiInteractionGeneratedQuestion", fields: [generatedQuestionId], references: [id], onDelete: SetNull)
  reviewStatus        AiReviewStatus @default(PENDING)
  reviewedAt          DateTime? // OHRANJENO; reviewedById odpade (pregledovalec == naročnik)
  createdAt           DateTime       @default(now())
  updatedAt           DateTime       @updatedAt

  @@index([aiModelId])
  @@index([requestedById])
  @@index([sourceQuestionId])
  @@index([generatedQuestionId])
  @@index([action])
  @@index([reviewStatus])
  // [REMOVED] reviewedById / reviewedBy  (+ njegov @@index)
}

// =============================================================================
// ENUMS  (vse vrednosti OHRANJENE — frontend tipi jih pričakujejo, tudi neuporabljene)
// =============================================================================
enum UserRole {
  ADMIN
  INSTRUCTOR
  PARTICIPANT
}

enum TrainingRole {
  // [NEW] per-training vloga v UserTraining (ADMIN je izključno globalen, zato ni tu)
  INSTRUCTOR
  PARTICIPANT
}

enum QuestionType {
  OPEN
  MULTIPLE_CHOICE
  CODE
}

enum QuestionStatus {
  DRAFT
  NEEDS_REVIEW
  REVIEW
  APPROVED
  REJECTED
  ARCHIVED
}

enum AiAction {
  GENERATE_QUESTION
  EDIT_QUESTION
  GENERATE_EQUIVALENT_QUESTION
  CHECK_EQUIVALENCE
  CHECK_QUESTION_QUALITY
  REVIEW_TEST
  GENERATE_SYNTHETIC_DATA
}

enum AiReviewStatus {
  PENDING
  ACCEPTED
  REJECTED
}

enum AiProvider {
  OLLAMA
  OPENAI
  DEEPSEEK
  OTHER
}

enum AssessmentType {
  PRE_TEST
  POST_TEST
  QUIZ
}

enum AssessmentStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum AttemptStatus {
  IN_PROGRESS
  SUBMITTED
  GRADED // zdaj dosegljiv prek zaključka ročnega ocenjevanja (C)
}
