generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id    Int    @id @default(autoincrement())
  email String @unique
  name  String
}

model Topic {
  id        Int        @id @default(autoincrement())
  name      String
  questions Question[]
}

model Question {
  id          Int    @id @default(autoincrement())
  title       String
  description String
  difficulty  Int

  topicId Int
  topic   Topic @relation(fields: [topicId], references: [id])
}