// =============================================================================
// PROJEKT3 — schema.prisma
// -----------------------------------------------------------------------------
// FAZA 0 (additive-only) different od schema-v2.prisma:
//   - NOVO se doda OB starem (nič DROP, nič NOT NULL, nič destruktivnih unique).
//   - Stari stolpci/tabele/relacije (LearningObjective, AssessmentBlueprint,
//     EquivalentQuestionGroup, reviewedById, equivalentGroupId) OSTANEJO za cutover.
//   - Destruktivni cutover (glej migration_docs/schema-v2.prisma) pride kasneje.
// =============================================================================

generator client {
  provider = "prisma-client-js"
}

// generator erd {
//   provider = "prisma-erd-generator"
// }

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id                      Int                 @id @default(autoincrement())
  firebaseUid             String?             @unique
  email                   String              @unique
  name                    String?
  externalAuthId          String?             @unique
  role                    UserRole            @default(PARTICIPANT)
  createdQuestions        Question[]          @relation("QuestionCreatedBy")
  reviewedQuestions       Question[]          @relation("QuestionReviewedBy")
  assessmentAttempts      AssessmentAttempt[]
  requestedAiInteractions AiInteraction[]     @relation("AiInteractionRequestedBy")
  reviewedAiInteractions  AiInteraction[]     @relation("AiInteractionReviewedBy")

  // [NEW][ADD] additive
  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt
  gradedAnswers       ParticipantAnswer[] @relation("AnswerGradedBy")
  trainingMemberships UserTraining[]
}

model Topic {
  id                 Int                 @id @default(autoincrement())
  name               String
  trainingId         Int
  training           Training            @relation(fields: [trainingId], references: [id])
  learningObjectives LearningObjective[]
  questions          Question[]

  // [NEW][ADD] additive
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Training {
  id                   Int                   @id @default(autoincrement())
  title                String
  description          String?
  createdAt            DateTime              @default(now())
  updatedAt            DateTime              @updatedAt
  topics               Topic[]
  assessments          Assessment[]
  assessmentBlueprints AssessmentBlueprint[]

  // [NEW][ADD] additive
  enrollmentToken   String?            @unique
  members           UserTraining[]
  equivalenceGroups EquivalenceGroup[]
}

// [NEW] vezna tabela User <-> Training (role INSTRUCTOR=lastništvo, PARTICIPANT=enrollment)
model UserTraining {
  id         Int          @id @default(autoincrement())
  userId     Int
  user       User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  trainingId Int
  training   Training     @relation(fields: [trainingId], references: [id], onDelete: Cascade)
  role       TrainingRole
  enrolledAt DateTime     @default(now())

  @@unique([userId, trainingId])
  @@index([trainingId, role])
}

model Question {
  id          Int    @id @default(autoincrement())
  title       String
  description String @db.Text // [CHANGED][ADD] VARCHAR(191) -> TEXT (širitev)
  difficulty  Int

  type   QuestionType   @default(OPEN)
  status QuestionStatus @default(DRAFT)

  topicId Int
  topic   Topic @relation(fields: [topicId], references: [id])

  learningObjectiveId Int?

  learningObjective LearningObjective? @relation(fields: [learningObjectiveId], references: [id])

  createdById Int
  createdBy   User @relation("QuestionCreatedBy", fields: [createdById], references: [id])

  reviewedById Int?
  reviewedBy   User?     @relation("QuestionReviewedBy", fields: [reviewedById], references: [id])
  reviewedAt   DateTime?

  answerOptions AnswerOption[]

  equivalentGroupId Int?
  equivalentGroup   EquivalentQuestionGroup? @relation(fields: [equivalentGroupId], references: [id], onDelete: SetNull)

  // [NEW][ADD] nov stolpec OB starem equivalentGroupId; kaže na novo EquivalenceGroup
  equivalenceGroupId Int?
  equivalenceGroup   EquivalenceGroup? @relation(fields: [equivalenceGroupId], references: [id], onDelete: SetNull)

  assessmentQuestions     AssessmentQuestion[]
  participantAnswers      ParticipantAnswer[]
  sourceAiInteractions    AiInteraction[]      @relation("AiInteractionSourceQuestion")
  generatedAiInteractions AiInteraction[]      @relation("AiInteractionGeneratedQuestion")

  // [NEW][ADD] additive
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([equivalentGroupId])
  @@index([equivalenceGroupId])
  @@index([status, topicId])
}

// [NEW] čista različica stare EquivalentQuestionGroup, scope-ana na training
model EquivalenceGroup {
  id          Int      @id @default(autoincrement())
  trainingId  Int
  training    Training @relation(fields: [trainingId], references: [id])
  title       String?
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  questions Question[]

  @@index([trainingId])
}

model AiModel {
  id           Int             @id @default(autoincrement())
  provider     AiProvider
  modelName    String
  displayName  String?
  baseUrl      String?
  isLocal      Boolean         @default(false)
  isActive     Boolean         @default(true)
  interactions AiInteraction[]
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt

  @@unique([provider, modelName])
}

model AiInteraction {
  id                  Int            @id @default(autoincrement())
  aiModelId           Int
  aiModel             AiModel        @relation(fields: [aiModelId], references: [id])
  requestedById       Int
  requestedBy         User           @relation("AiInteractionRequestedBy", fields: [requestedById], references: [id])
  action              AiAction
  prompt              String         @db.LongText
  resultText          String?        @db.LongText
  resultJson          Json?
  sourceQuestionId    Int?
  sourceQuestion      Question?      @relation("AiInteractionSourceQuestion", fields: [sourceQuestionId], references: [id], onDelete: SetNull)
  generatedQuestionId Int?
  generatedQuestion   Question?      @relation("AiInteractionGeneratedQuestion", fields: [generatedQuestionId], references: [id], onDelete: SetNull)
  reviewStatus        AiReviewStatus @default(PENDING)
  reviewedById        Int?
  reviewedBy          User?          @relation("AiInteractionReviewedBy", fields: [reviewedById], references: [id])
  reviewedAt          DateTime?
  createdAt           DateTime       @default(now())
  updatedAt           DateTime       @updatedAt

  @@index([aiModelId])
  @@index([requestedById])
  @@index([reviewedById])
  @@index([sourceQuestionId])
  @@index([generatedQuestionId])
  @@index([action])
  @@index([reviewStatus])
}

model Assessment {
  id               Int                  @id @default(autoincrement())
  title            String
  description      String?
  trainingId       Int
  training         Training             @relation(fields: [trainingId], references: [id])
  type             AssessmentType
  status           AssessmentStatus     @default(DRAFT)
  timeLimitMinutes Int?
  createdAt        DateTime             @default(now())
  updatedAt        DateTime             @updatedAt
  questions        AssessmentQuestion[]
  attempts         AssessmentAttempt[]

  // [NEW][ADD] pre/post pairing (self 1:1). @unique je nujen za 1:1 relacijo v Prisma;
  // varen v FAZI 0, ker je stolpec nov in povsod NULL (dovoljeni večkratni NULL).
  pairedAssessmentId Int?        @unique
  pairedAssessment   Assessment? @relation("AssessmentPairing", fields: [pairedAssessmentId], references: [id], onDelete: SetNull)
  pairedBy           Assessment? @relation("AssessmentPairing")

  @@index([status, trainingId])
}

model AssessmentBlueprint {
  id                  Int      @id @default(autoincrement())
  title               String
  description         String?
  trainingId          Int
  training            Training @relation(fields: [trainingId], references: [id])
  targetQuestionCount Int
  configJson          Json
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
}

model AssessmentQuestion {
  id           Int        @id @default(autoincrement())
  assessmentId Int
  assessment   Assessment @relation(fields: [assessmentId], references: [id], onDelete: Cascade)
  questionId   Int
  question     Question   @relation(fields: [questionId], references: [id])
  orderIndex   Int
  points       Float      @default(1)

  @@unique([assessmentId, orderIndex])
  @@unique([assessmentId, questionId])
  @@index([questionId])
}

model AssessmentAttempt {
  id           Int                 @id @default(autoincrement())
  assessmentId Int
  assessment   Assessment          @relation(fields: [assessmentId], references: [id])
  userId       Int?
  user         User?               @relation(fields: [userId], references: [id], onDelete: SetNull)
  startedAt    DateTime            @default(now())
  submittedAt  DateTime?
  score        Float?
  maxScore     Float?
  status       AttemptStatus       @default(IN_PROGRESS)
  answers      ParticipantAnswer[]
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt

  @@index([assessmentId])
  @@index([userId])
  @@index([status])
  // NOTE: @@unique([assessmentId, userId]) NAMENOMA IZPUŠČEN v FAZI 0 (zahteva dedup — cutover)
}

model ParticipantAnswer {
  id                Int               @id @default(autoincrement())
  attemptId         Int
  attempt           AssessmentAttempt @relation(fields: [attemptId], references: [id], onDelete: Cascade)
  questionId        Int
  question          Question          @relation(fields: [questionId], references: [id])
  selectedOptionId  Int?
  selectedOption    AnswerOption?     @relation(fields: [selectedOptionId], references: [id])
  answerText        String?           @db.Text // [CHANGED][ADD] VARCHAR(191) -> TEXT
  isCorrect         Boolean?
  pointsAwarded     Float?
  needsManualReview Boolean           @default(false)
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt

  // [NEW][ADD] ročno ocenjevanje OPEN/CODE
  gradedById Int?
  gradedBy   User?     @relation("AnswerGradedBy", fields: [gradedById], references: [id], onDelete: SetNull)
  gradedAt   DateTime?

  @@unique([attemptId, questionId])
  @@index([questionId])
  @@index([selectedOptionId])
  @@index([gradedById])
}

model AnswerOption {
  id         Int      @id @default(autoincrement())
  questionId Int
  question   Question @relation(fields: [questionId], references: [id], onDelete: Cascade)
  text       String
  isCorrect  Boolean  @default(false)
  orderIndex Int

  participantAnswers ParticipantAnswer[]

  @@unique([questionId, orderIndex])
  @@index([questionId])
}

model EquivalentQuestionGroup {
  id          Int        @id @default(autoincrement())
  name        String
  description String?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  questions   Question[]
}

model LearningObjective {
  id          Int     @id @default(autoincrement())
  title       String
  description String?
  topicId     Int
  topic       Topic   @relation(fields: [topicId], references: [id])

  questions Question[]
}

enum QuestionType {
  OPEN
  MULTIPLE_CHOICE
  CODE
}

enum QuestionStatus {
  DRAFT
  NEEDS_REVIEW
  REVIEW
  APPROVED
  REJECTED
  ARCHIVED
}

enum AiAction {
  GENERATE_QUESTION
  EDIT_QUESTION
  GENERATE_EQUIVALENT_QUESTION
  CHECK_EQUIVALENCE
  CHECK_QUESTION_QUALITY
  REVIEW_TEST
  GENERATE_SYNTHETIC_DATA
}

enum AiReviewStatus {
  PENDING
  ACCEPTED
  REJECTED
}

enum AiProvider {
  OLLAMA
  OPENAI
  DEEPSEEK
  OTHER
}

enum AssessmentType {
  PRE_TEST
  POST_TEST
  QUIZ
}

enum AssessmentStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum AttemptStatus {
  IN_PROGRESS
  SUBMITTED
  GRADED
}

enum UserRole {
  ADMIN
  INSTRUCTOR
  PARTICIPANT
}

// [NEW] per-training vloga v UserTraining (ADMIN je izključno globalen, zato ni tu)
enum TrainingRole {
  INSTRUCTOR
  PARTICIPANT
}
