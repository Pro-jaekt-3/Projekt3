generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id                Int        @id @default(autoincrement())
  email             String     @unique
  name              String
  externalAuthId    String?    @unique
  role              UserRole   @default(PARTICIPANT)
  createdQuestions  Question[] @relation("QuestionCreatedBy")
  reviewedQuestions Question[] @relation("QuestionReviewedBy")
}

model Topic {
  id                 Int                 @id @default(autoincrement())
  name               String
  trainingId         Int
  training           Training            @relation(fields: [trainingId], references: [id])
  learningObjectives LearningObjective[]
  questions          Question[]
}

model Training {
  id          Int          @id @default(autoincrement())
  title       String
  description String?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  topics      Topic[]
  assessments Assessment[]
}

model Question {
  id          Int    @id @default(autoincrement())
  title       String
  description String
  difficulty  Int

  type   QuestionType   @default(OPEN)
  status QuestionStatus @default(DRAFT)

  topicId Int
  topic   Topic @relation(fields: [topicId], references: [id])

  learningObjectiveId Int?

  learningObjective LearningObjective? @relation(fields: [learningObjectiveId], references: [id])

  createdById Int
  createdBy   User @relation("QuestionCreatedBy", fields: [createdById], references: [id])

  reviewedById Int?
  reviewedBy   User?     @relation("QuestionReviewedBy", fields: [reviewedById], references: [id])
  reviewedAt   DateTime?

  answerOptions AnswerOption[]

  equivalentGroupId Int?
  equivalentGroup   EquivalentQuestionGroup? @relation(fields: [equivalentGroupId], references: [id], onDelete: SetNull)

  assessmentQuestions AssessmentQuestion[]

  @@index([equivalentGroupId])
}

model Assessment {
  id               Int                  @id @default(autoincrement())
  title            String
  description      String?
  trainingId       Int
  training         Training             @relation(fields: [trainingId], references: [id])
  type             AssessmentType
  status           AssessmentStatus     @default(DRAFT)
  timeLimitMinutes Int?
  createdAt        DateTime             @default(now())
  updatedAt        DateTime             @updatedAt
  questions        AssessmentQuestion[]
}

model AssessmentQuestion {
  id           Int        @id @default(autoincrement())
  assessmentId Int
  assessment   Assessment @relation(fields: [assessmentId], references: [id], onDelete: Cascade)
  questionId   Int
  question     Question   @relation(fields: [questionId], references: [id])
  orderIndex   Int
  points       Float      @default(1)

  @@unique([assessmentId, orderIndex])
  @@unique([assessmentId, questionId])
  @@index([questionId])
}

model AnswerOption {
  id         Int      @id @default(autoincrement())
  questionId Int
  question   Question @relation(fields: [questionId], references: [id], onDelete: Cascade)
  text       String
  isCorrect  Boolean  @default(false)
  orderIndex Int

  @@unique([questionId, orderIndex])
  @@index([questionId])
}

model EquivalentQuestionGroup {
  id          Int        @id @default(autoincrement())
  name        String
  description String?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  questions   Question[]
}

model LearningObjective {
  id          Int     @id @default(autoincrement())
  title       String
  description String?
  topicId     Int
  topic       Topic   @relation(fields: [topicId], references: [id])

  questions Question[]
}

enum QuestionType {
  OPEN
  MULTIPLE_CHOICE
  CODE
}

enum QuestionStatus {
  DRAFT
  NEEDS_REVIEW
  REVIEW
  APPROVED
  REJECTED
  ARCHIVED
}

enum AssessmentType {
  PRE_TEST
  POST_TEST
  QUIZ
}

enum AssessmentStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum UserRole {
  ADMIN
  INSTRUCTOR
  PARTICIPANT
}
