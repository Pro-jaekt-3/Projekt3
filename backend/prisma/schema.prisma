generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id                      Int                 @id @default(autoincrement())
  email                   String              @unique
  name                    String
  externalAuthId          String?             @unique
  role                    UserRole            @default(PARTICIPANT)
  createdQuestions        Question[]          @relation("QuestionCreatedBy")
  reviewedQuestions       Question[]          @relation("QuestionReviewedBy")
  assessmentAttempts      AssessmentAttempt[]
  requestedAiInteractions AiInteraction[]     @relation("AiInteractionRequestedBy")
  reviewedAiInteractions  AiInteraction[]     @relation("AiInteractionReviewedBy")
}

model Topic {
  id                 Int                 @id @default(autoincrement())
  name               String
  trainingId         Int
  training           Training            @relation(fields: [trainingId], references: [id])
  learningObjectives LearningObjective[]
  questions          Question[]
}

model Training {
  id                   Int                   @id @default(autoincrement())
  title                String
  description          String?
  createdAt            DateTime              @default(now())
  updatedAt            DateTime              @updatedAt
  topics               Topic[]
  assessments          Assessment[]
  assessmentBlueprints AssessmentBlueprint[]
}

model Question {
  id          Int    @id @default(autoincrement())
  title       String
  description String
  difficulty  Int

  type   QuestionType   @default(OPEN)
  status QuestionStatus @default(DRAFT)

  topicId Int
  topic   Topic @relation(fields: [topicId], references: [id])

  learningObjectiveId Int?

  learningObjective LearningObjective? @relation(fields: [learningObjectiveId], references: [id])

  createdById Int
  createdBy   User @relation("QuestionCreatedBy", fields: [createdById], references: [id])

  reviewedById Int?
  reviewedBy   User?     @relation("QuestionReviewedBy", fields: [reviewedById], references: [id])
  reviewedAt   DateTime?

  answerOptions AnswerOption[]

  equivalentGroupId Int?
  equivalentGroup   EquivalentQuestionGroup? @relation(fields: [equivalentGroupId], references: [id], onDelete: SetNull)

  assessmentQuestions     AssessmentQuestion[]
  participantAnswers      ParticipantAnswer[]
  sourceAiInteractions    AiInteraction[]      @relation("AiInteractionSourceQuestion")
  generatedAiInteractions AiInteraction[]      @relation("AiInteractionGeneratedQuestion")

  @@index([equivalentGroupId])
}

model AiModel {
  id           Int             @id @default(autoincrement())
  provider     AiProvider
  modelName    String
  displayName  String?
  baseUrl      String?
  isLocal      Boolean         @default(false)
  isActive     Boolean         @default(true)
  interactions AiInteraction[]
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt

  @@unique([provider, modelName])
}

model AiInteraction {
  id                  Int            @id @default(autoincrement())
  aiModelId           Int
  aiModel             AiModel        @relation(fields: [aiModelId], references: [id])
  requestedById       Int
  requestedBy         User           @relation("AiInteractionRequestedBy", fields: [requestedById], references: [id])
  action              AiAction
  prompt              String         @db.LongText
  resultText          String?        @db.LongText
  resultJson          Json?
  sourceQuestionId    Int?
  sourceQuestion      Question?      @relation("AiInteractionSourceQuestion", fields: [sourceQuestionId], references: [id], onDelete: SetNull)
  generatedQuestionId Int?
  generatedQuestion   Question?      @relation("AiInteractionGeneratedQuestion", fields: [generatedQuestionId], references: [id], onDelete: SetNull)
  reviewStatus        AiReviewStatus @default(PENDING)
  reviewedById        Int?
  reviewedBy          User?          @relation("AiInteractionReviewedBy", fields: [reviewedById], references: [id])
  reviewedAt          DateTime?
  createdAt           DateTime       @default(now())
  updatedAt           DateTime       @updatedAt

  @@index([aiModelId])
  @@index([requestedById])
  @@index([reviewedById])
  @@index([sourceQuestionId])
  @@index([generatedQuestionId])
  @@index([action])
  @@index([reviewStatus])
}

model Assessment {
  id               Int                  @id @default(autoincrement())
  title            String
  description      String?
  trainingId       Int
  training         Training             @relation(fields: [trainingId], references: [id])
  type             AssessmentType
  status           AssessmentStatus     @default(DRAFT)
  timeLimitMinutes Int?
  createdAt        DateTime             @default(now())
  updatedAt        DateTime             @updatedAt
  questions        AssessmentQuestion[]
  attempts         AssessmentAttempt[]
}

model AssessmentBlueprint {
  id                  Int      @id @default(autoincrement())
  title               String
  description         String?
  trainingId          Int
  training            Training @relation(fields: [trainingId], references: [id])
  targetQuestionCount Int
  configJson          Json
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
}

model AssessmentQuestion {
  id           Int        @id @default(autoincrement())
  assessmentId Int
  assessment   Assessment @relation(fields: [assessmentId], references: [id], onDelete: Cascade)
  questionId   Int
  question     Question   @relation(fields: [questionId], references: [id])
  orderIndex   Int
  points       Float      @default(1)

  @@unique([assessmentId, orderIndex])
  @@unique([assessmentId, questionId])
  @@index([questionId])
}

model AssessmentAttempt {
  id           Int                 @id @default(autoincrement())
  assessmentId Int
  assessment   Assessment          @relation(fields: [assessmentId], references: [id])
  userId       Int?
  user         User?               @relation(fields: [userId], references: [id], onDelete: SetNull)
  startedAt    DateTime            @default(now())
  submittedAt  DateTime?
  score        Float?
  maxScore     Float?
  status       AttemptStatus       @default(IN_PROGRESS)
  answers      ParticipantAnswer[]
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt

  @@index([assessmentId])
  @@index([userId])
  @@index([status])
}

model ParticipantAnswer {
  id                Int               @id @default(autoincrement())
  attemptId         Int
  attempt           AssessmentAttempt @relation(fields: [attemptId], references: [id], onDelete: Cascade)
  questionId        Int
  question          Question          @relation(fields: [questionId], references: [id])
  selectedOptionId  Int?
  selectedOption    AnswerOption?     @relation(fields: [selectedOptionId], references: [id])
  answerText        String?
  isCorrect         Boolean?
  pointsAwarded     Float?
  needsManualReview Boolean           @default(false)
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt

  @@unique([attemptId, questionId])
  @@index([questionId])
  @@index([selectedOptionId])
}

model AnswerOption {
  id         Int      @id @default(autoincrement())
  questionId Int
  question   Question @relation(fields: [questionId], references: [id], onDelete: Cascade)
  text       String
  isCorrect  Boolean  @default(false)
  orderIndex Int

  participantAnswers ParticipantAnswer[]

  @@unique([questionId, orderIndex])
  @@index([questionId])
}

model EquivalentQuestionGroup {
  id          Int        @id @default(autoincrement())
  name        String
  description String?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  questions   Question[]
}

model LearningObjective {
  id          Int     @id @default(autoincrement())
  title       String
  description String?
  topicId     Int
  topic       Topic   @relation(fields: [topicId], references: [id])

  questions Question[]
}

enum QuestionType {
  OPEN
  MULTIPLE_CHOICE
  CODE
}

enum QuestionStatus {
  DRAFT
  NEEDS_REVIEW
  REVIEW
  APPROVED
  REJECTED
  ARCHIVED
}

enum AiAction {
  GENERATE_QUESTION
  EDIT_QUESTION
  GENERATE_EQUIVALENT_QUESTION
  CHECK_EQUIVALENCE
  CHECK_QUESTION_QUALITY
  REVIEW_TEST
  GENERATE_SYNTHETIC_DATA
}

enum AiReviewStatus {
  PENDING
  ACCEPTED
  REJECTED
}

enum AiProvider {
  OLLAMA
  OPENAI
  DEEPSEEK
  OTHER
}

enum AssessmentType {
  PRE_TEST
  POST_TEST
  QUIZ
}

enum AssessmentStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum AttemptStatus {
  IN_PROGRESS
  SUBMITTED
  GRADED
}

enum UserRole {
  ADMIN
  INSTRUCTOR
  PARTICIPANT
}
