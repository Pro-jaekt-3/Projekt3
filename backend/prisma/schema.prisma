generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id    Int    @id @default(autoincrement())
  email String @unique
  name  String
}

model Topic {
  id        Int        @id @default(autoincrement())
  name      String
  questions Question[]
}

model Question {
  id          Int    @id @default(autoincrement())
  title       String
  description String
  difficulty  Int

  type QuestionType @default(OPEN)

  topicId Int
  topic   Topic @relation(fields: [topicId], references: [id])

  learningObjectiveId Int?

  learningObjective LearningObjective? @relation(fields: [learningObjectiveId], references: [id])
  
}

model LearningObjective {
  id          Int    @id @default(autoincrement())
  title       String
  description String?

  questions Question[]
}

model Training {
  id          Int       @id @default(autoincrement())
  title       String
  description String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

enum QuestionType {
  OPEN
  MULTIPLE_CHOICE
  CODE
}